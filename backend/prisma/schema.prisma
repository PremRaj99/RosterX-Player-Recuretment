// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum UserRole {
  guest
  player
  captain
  manager
  recruiter
  org_admin
  organizer
  sponsor
  coach
  analyst
  moderator
  platform_admin
}

enum UserStatus {
  active
  suspended
  banned
  deleted
}

enum ProfileVisibility {
  public
  followers
  private
}

enum Theme {
  dark
  light
}

enum RecruitmentStatus {
  open
  closed
  flagged
  removed
}

enum ApplicationStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum SponsorshipStatus {
  pending
  approved
  declined
  active
  completed
}

enum NotificationCategory {
  recruitment
  applications
  messages
  teams
  organizations
  sponsors
  tournaments
  platform
  security
  verification
}

// ----------------------------------------------------------------------
// EMBEDDED TYPES
// ----------------------------------------------------------------------

type UserSettings {
  profileVisibility   ProfileVisibility @default(public)
  showOnlineStatus     Boolean           @default(true)
  allowDirectMessages   Boolean           @default(true)
  showInSearch          Boolean           @default(true)
  theme                 Theme             @default(dark)
  language              String            @default("en")
  region                String?
  notificationPrefs     NotificationPrefs
}

type NotificationPrefs {
  recruitment   Boolean @default(true)
  applications  Boolean @default(true)
  messages      Boolean @default(true)
  teams         Boolean @default(true)
  organizations Boolean @default(true)
  sponsors      Boolean @default(true)
  tournaments   Boolean @default(true)
  platform      Boolean @default(true)
  security      Boolean @default(true)
}

type PlayerStats {
  kdRatio       Float @default(0)
  winRate       Float @default(0)
  matchesPlayed Int   @default(0)
  mvpCount      Int   @default(0)
}

type PlayerAchievement {
  title       String
  description String?
  awardedAt   DateTime @default(now())
}

type TeamMember {
  playerId   String   @db.ObjectId
  roleOnTeam String   @default("Member")
  joinedAt   DateTime @default(now())
}

// ----------------------------------------------------------------------
// MODELS
// ----------------------------------------------------------------------

model User {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  email             String               @unique
  passwordHash      String
  username          String               @unique
  displayName       String
  role              UserRole             @default(player)
  emailVerified     Boolean              @default(false)
  phone             String?
  phoneVerified     Boolean              @default(false)
  avatarUrl         String?
  bio               String?
  country           String?
  status            UserStatus           @default(active)
  twoFactorEnabled  Boolean              @default(false)
  settings          UserSettings

  playerProfile     Player?
  organizations     Organization[]
  sponsorships      SponsorshipRequest[]
  
  // Relations for Chat/Messaging
  threadIds         String[]             @db.ObjectId
  threads           ChatThread[]         @relation("ThreadParticipants", fields: [threadIds], references: [id])
  sentMessages      ChatMessage[]        @relation("SentMessages")
  readMessageIds    String[]             @db.ObjectId
  readMessages      ChatMessage[]        @relation("MessagesRead", fields: [readMessageIds], references: [id])

  notifications     Notification[]

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model Player {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  userId       String              @unique @db.ObjectId
  user         User                @relation(fields: [userId], references: [id])
  mainGame     String
  primaryRole  String
  rank         String
  verified     Boolean             @default(false)
  teamId       String?             @db.ObjectId
  team         Team?               @relation("PlayerTeam", fields: [teamId], references: [id])
  stats        PlayerStats
  achievements PlayerAchievement[]

  applications Application[]

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Organization {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String               @db.ObjectId
  owner       User                 @relation(fields: [ownerId], references: [id])
  name        String               @unique
  slug        String               @unique
  logoUrl     String?
  games       String[]
  description String?
  verified    Boolean              @default(false)
  verifiedAt  DateTime?
  rosterSize  Int                  @default(0)

  teams        Team[]
  recruitments Recruitment[]
  applications Application[]
  sponsorships SponsorshipRequest[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Team {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String?       @db.ObjectId
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  game           String
  logoUrl        String?
  winRate        Float         @default(0)
  members        TeamMember[]

  players        Player[]      @relation("PlayerTeam")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Recruitment {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String            @db.ObjectId
  organization   Organization      @relation(fields: [organizationId], references: [id])
  title          String
  game           String
  roleNeeded     String
  description    String
  status         RecruitmentStatus @default(open)

  applications Application[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Application {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  recruitmentId  String?           @db.ObjectId
  recruitment    Recruitment?      @relation(fields: [recruitmentId], references: [id])
  organizationId String            @db.ObjectId
  organization   Organization      @relation(fields: [organizationId], references: [id])
  playerId       String            @db.ObjectId
  player         Player            @relation(fields: [playerId], references: [id])
  message        String?
  status         ApplicationStatus @default(pending)
  decidedAt      DateTime?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model SponsorshipRequest {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  sponsorId      String            @db.ObjectId
  sponsor        User              @relation(fields: [sponsorId], references: [id])
  organizationId String            @db.ObjectId
  organization   Organization      @relation(fields: [organizationId], references: [id])
  value          String
  durationMonths Int
  status         SponsorshipStatus @default(pending)
  decidedAt      DateTime?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ChatThread {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  participantIds String[]      @db.ObjectId
  participants   User[]        @relation("ThreadParticipants", fields: [participantIds], references: [id])
  lastMessageId  String?       @unique @db.ObjectId
  lastMessage    ChatMessage?  @relation("ThreadLastMessage", fields: [lastMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages       ChatMessage[] @relation("ThreadMessages")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String      @db.ObjectId
  thread    ChatThread  @relation("ThreadMessages", fields: [threadId], references: [id])
  senderId  String      @db.ObjectId
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  text      String
  readByIds String[]    @db.ObjectId
  readBy    User[]      @relation("MessagesRead", fields: [readByIds], references: [id])

  lastInThread ChatThread? @relation("ThreadLastMessage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String               @id @default(auto()) @map("_id") @db.ObjectId
  userId    String               @db.ObjectId
  user      User                 @relation(fields: [userId], references: [id])
  category  NotificationCategory
  title     String
  body      String?
  read      Boolean              @default(false)

  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}
