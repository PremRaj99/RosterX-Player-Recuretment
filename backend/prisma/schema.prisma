// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum UserRole {
  patient
  therapist
  admin
}

enum UserStatus {
  blocked
  deleted
  active
}

enum Gender {
  male
  female
  other
}

enum PaymentMethodId {
  bank_transfer
  upi
}

enum ReviewedBy {
  patient
  therapist
}

enum SessionStatus {
  pending // slot locked, payment pending
  confirmed // payment success
  active // OTP verified (therapist arrived)
  completed // therapist finished session
  settled // commission released
  cancelled // cancelled before start
  no_show // therapist or patient didn't show up
  expired // payment not completed
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum PaymentPurpose {
  therapy_session
  subscription
}

enum BillStatus {
  unclaimed
  released
  refunded
}

enum PayoutStatus {
  requested
  rejected
  processed
}

enum WalletType {
  earning
  payout
  penalty
  adjust
  hold
}

enum TreatmentPlanStatus {
  created
  treatment_planned
  ongoing
  completed
  cancelled
  abandoned
}

enum TreatmentMode {
  home_visit
  online
  clinic
}

enum CouponStatus {
  active
  inactive
}

enum CouponUsageStatus {
  reserved
  consumed
  reverted
}

enum CouponAssignmentType {
  whitelist
  blacklist
}

enum ReservationStatus {
  booked
  blocked
}

enum ActivityType {
  frequent
  likely
  possible
  rare
  unlikely
}

enum NotificationPriority {
  low
  medium
  high
}

// ----------------------------------------------------------------------
// USER & AUTH DOMAIN
// ----------------------------------------------------------------------

model User {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String
  phone    String?
  password String
  image    String?
  role     UserRole
  status   UserStatus

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Auth Sessions
  authSessions AuthSession[]

  // Profiles (1:1 Relationships)
  patientProfile   Patient?
  therapistProfile Therapist?

  // Financials (User pays, regardless of role)
  payments Payment[]

  // Content Interactions
  writtenBlogReviews BlogReview[] @relation("WrittenReviews")
  blogLikes          BlogLike[]

  // System
  activities    Activity[]
  notifications Notification[]
  complaint     Complaint[]

  @@unique([email, deletedAt])
  @@index([phone])
}

model AuthSession {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  agent        String
  location     String
  ip           String
  refreshToken String    @unique
  lastLoggedAt DateTime?
  expiredAt    DateTime
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ----------------------------------------------------------------------
// PATIENT DOMAIN
// ----------------------------------------------------------------------

model Patient {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @unique @db.ObjectId // 1:1 Link to User
  patientId String // Public Business ID (e.g. PAT-2024-001)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id])

  details           PatientDetail[]
  locations         PatientLocation[]
  treatmentPlans    TreatmentPlan[]    @relation("PatientTreatmentPlans")
  reviewsGiven      TherapistReview[]  @relation("PatientGivenReviews")
  couponUsages      CouponUsage[]
  couponAssignments CouponAssignment[]
  reservations      SlotReservation[]
  patientReviews    PatientReview[]

  @@unique([userId, deletedAt])
  @@index([patientId])
}

model PatientDetail {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  patientId String @db.ObjectId

  name   String
  dob    DateTime
  gender Gender
  phone  String
  heightCm Float
  weightKg Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patient Patient @relation(fields: [patientId], references: [id])
}

model PatientReview {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId     String @db.ObjectId
  treatmentPlanId String @db.ObjectId

  comment String
  rating  Float

  createdAt DateTime  @default(now())
  deletedAt DateTime?
  patient   Patient   @relation(fields: [patientId], references: [id])
  patientId String    @db.ObjectId

  @@index([therapistId])
  @@index([patientId])
}

// ----------------------------------------------------------------------
// SHARED LOCATION
// ----------------------------------------------------------------------

model PatientLocation {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  patientId String @db.ObjectId

  address    String
  landmark   String?
  city       String
  state      String
  country    String
  postalCode String
  location   Json // { lat: number, lng: number }

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Polymorphic-style relations
  patient Patient @relation(fields: [patientId], references: [id])
}

model TherapistLocation {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String? @db.ObjectId

  address    String
  landmark   String?
  city       String
  state      String
  country    String
  postalCode String
  location   Json // { lat: number, lng: number }

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Back relation to TherapistMeta (defined on TherapistMeta.location)
  therapistMeta TherapistMeta?
}

// ----------------------------------------------------------------------
// THERAPIST DOMAIN
// ----------------------------------------------------------------------

model Therapist {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @unique @db.ObjectId // 1:1 Link to User
  therapistId String // Public Business ID

  location               Json // Current GPS { lat: number, lng: number }
  displayAddress         String
  price                  Float
  priceAlt               Float?
  commissionRate         Float
  updateCommissionRateAt DateTime?

  rating Float?

  gender Gender
  mode   TreatmentMode
  clinic String?
  about  String?

  verifiedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  meta             TherapistMeta?
  accounts         AccountDetail[]
  treatmentPlans   TreatmentPlan[]    @relation("TherapistTreatmentPlans")
  commissions      Commission[]
  walletEntries    TherapistWallet[]
  payouts          Payout[]
  articles         TherapistArticle[]
  faqs             TherapistFAQ[]
  reviewsReceived  TherapistReview[]  @relation("TherapistReceivedReviews")
  subscriptions    Subscription[]
  slots            TherapistSlot[]
  leaves           TherapistLeave[]
  slotReservations SlotReservation[]

  // Coupons created by this therapist (if allowed)
  generatedCoupons Coupon[]
  couponConfig     CouponTherapist[]

  @@unique([userId, deletedAt])
  @@index([therapistId])
}

model TherapistMeta {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @unique @db.ObjectId
  locationId  String @unique @db.ObjectId

  dob                      DateTime
  experience               Int
  specialization           String[]
  languagesSpoken          String[]
  educationQualification   String[]
  currentlyAffiliation     String?
  IAPId                    String?
  resume                   String?
  professionalCertificates String[]

  therapist Therapist          @relation(fields: [therapistId], references: [id])
  location  TherapistLocation? @relation(fields: [locationId], references: [id])
}

model AccountDetail {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  accountHolderName String?
  bankName          String?
  branchName        String?
  accountNumber     String?
  ifsc              String?
  upi               String?

  isDefault    Boolean          @default(false)
  payoutMethod PaymentMethodId?

  deletedAt DateTime?

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model TherapistArticle {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  title   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model TherapistFAQ {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  question String
  answer   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

// ----------------------------------------------------------------------
// TREATMENT PLANS & SESSIONS
// ----------------------------------------------------------------------

model TreatmentPlan {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String @db.ObjectId
  therapistId     String @db.ObjectId
  locationId      String @db.ObjectId
  patientDetailId String @db.ObjectId

  status                 TreatmentPlanStatus
  suggestedTreatmentDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Redundant fields for easier querying and reporting
  patientDetailsSnapshot Json // Store patient details at time of booking for reporting
  locationSnapshot       Json // Store location details at time of booking for reporting
  therapistSnapshot      Json // Store therapist details at time of booking for reporting

  // Relations
  patient   Patient            @relation("PatientTreatmentPlans", fields: [patientId], references: [id])
  therapist Therapist          @relation("TherapistTreatmentPlans", fields: [therapistId], references: [id])
  sessions  TreatmentSession[]

  // Todo: Assessment reports, prescriptions, etc. can be linked here as they evolve

  @@index([patientId])
  @@index([therapistId])
}

model TreatmentSession {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  treatmentPlanId String @db.ObjectId
  reservationId   String @unique @db.ObjectId

  date   DateTime
  status SessionStatus
  mode   TreatmentMode
  condition String
  DescribedAs String?

  // Fraud Prevention & Logistics
  startAt DateTime?

  cancelledBy        ReviewedBy?
  cancelledAt        DateTime?
  cancellationReason String?

  endAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // add redundant fields for easier querying and reporting
  therapistSnapshot     Json
  patientDetailSnapshot Json
  priceAtBooking        Float
  addressSnapshot       Json?

  // Relations
  treatmentPlan TreatmentPlan           @relation(fields: [treatmentPlanId], references: [id])
  bill          TreatmentSessionBill?
  review        TreatmentSessionReview?
  couponUsage   CouponUsage?

  // Linked Reservation (Which slot was used)
  reservation              SlotReservation @relation(fields: [reservationId], references: [id])
  treatmentSessionReviewId String?         @db.ObjectId

  @@index([treatmentPlanId])
}

// ----------------------------------------------------------------------
// SCHEDULING & SLOTS
// ----------------------------------------------------------------------

model TimeSlotTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  startTime    Int // Minutes from midnight
  endTime      Int
  slotDuration Int // minutes
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())

  // Relations
  reservations SlotReservation[]
}

model TherapistSlot {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  availableDays String[] // ["mon", "wed"]

  createdAt DateTime @default(now())

  therapist    Therapist         @relation(fields: [therapistId], references: [id])
  reservations SlotReservation[]

  @@index([therapistId])
}

model TherapistLeave {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  startDate DateTime
  endDate   DateTime
  reason    String?

  createdAt DateTime @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model SlotReservation {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String  @db.ObjectId
  patientId   String? @db.ObjectId

  therapistSlotId    String? @db.ObjectId
  timeSlotTemplateId String  @db.ObjectId
  treatmentSessionId String? @unique @db.ObjectId // Becomes linked when session is created

  startTime DateTime
  endTime   DateTime

  date      DateTime
  status    ReservationStatus
  expiresAt DateTime? // For "hold" status
  deletedAt DateTime?

  // Relations
  therapist        Therapist         @relation(fields: [therapistId], references: [id])
  timeSlotTemplate TimeSlotTemplate  @relation(fields: [timeSlotTemplateId], references: [id])
  patient          Patient?          @relation(fields: [patientId], references: [id])
  therapistSlot    TherapistSlot?    @relation(fields: [therapistSlotId], references: [id])
  treatmentSession TreatmentSession?

  @@unique([therapistId, date, timeSlotTemplateId])
  @@index([patientId])
}

// ----------------------------------------------------------------------
// BILLING, PAYMENTS & WALLET
// ----------------------------------------------------------------------

model Payment {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  invoiceId String @unique

  gatewayPaymentId String?
  gatewayOrderId   String?
  webhookEventId   String? @unique
  processing       Boolean @default(false)

  status PaymentStatus
  amount Float

  paidAt      DateTime?
  failedAt    DateTime?
  refundedAt  DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription logic
  purpose        PaymentPurpose @default(therapy_session)
  subscriptionId String?        @db.ObjectId

  // Relations
  user         User                   @relation(fields: [userId], references: [id])
  subscription Subscription?          @relation(fields: [subscriptionId], references: [id])
  bills        TreatmentSessionBill[]

  @@index([userId])
  @@index([gatewayPaymentId, status])
}

model TreatmentSessionBill {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  paymentId String @db.ObjectId
  sessionId String @unique @db.ObjectId

  sessionDate DateTime
  therapistId String
  patientId   String

  amountAllocated Float
  status          BillStatus
  releasedAt      DateTime?

  // Redundant fields for easier querying and reporting
  paymentAmountMetaData Json // Store original payment amount as string for reporting, since payments can be split or adjusted

  // Relations
  payment    Payment          @relation(fields: [paymentId], references: [id])
  session    TreatmentSession @relation(fields: [sessionId], references: [id])
  commission Commission?

  @@index([paymentId])
}

model Commission {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  billId      String @unique @db.ObjectId
  therapistId String @db.ObjectId

  therapistName String
  sessionDate   DateTime
  patientName   String

  sessionAmount    Float
  platformFee      Float
  therapistAmount  Float
  platformRateUsed Float

  calculatedAt DateTime @default(now())

  // Relations
  bill      TreatmentSessionBill @relation(fields: [billId], references: [id])
  therapist Therapist            @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model TherapistWallet {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  amount       Float
  type         WalletType
  referenceId  String? // ID of Payout or Commission
  balanceHold  Float?
  balanceAfter Float?

  createdAt DateTime @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model Payout {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  amount              Float
  status              PayoutStatus
  transactionRef      String? // utr or transaction ID from payment gateway
  processedBy         String?
  processedAt         DateTime?
  requestedFromIp     String?
  accountSnapshotJson Json? // Store account details at time of payout for record

  createdAt DateTime @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id])

  @@unique([transactionRef])
  @@index([therapistId])
}

model Subscription {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String @db.ObjectId

  isActive  Boolean
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapist Therapist @relation(fields: [therapistId], references: [id])
  payments  Payment[]

  @@index([therapistId])
}

// ----------------------------------------------------------------------
// COUPONS
// ----------------------------------------------------------------------

model Coupon {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  therapistId String? @db.ObjectId // Optional: If specific to a therapist

  code      String
  discount  Float
  minPrice  Float
  expiresOn DateTime
  status    CouponStatus
  isGlobal  Boolean

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  therapist            Therapist?         @relation(fields: [therapistId], references: [id])
  usages               CouponUsage[]
  assignments          CouponAssignment[]
  therapistConstraints CouponTherapist[] // If limited to list of therapists

  @@unique([code, deletedAt])
}

model CouponUsage {
  id                 String @id @default(auto()) @map("_id") @db.ObjectId
  couponId           String @db.ObjectId
  patientId          String @db.ObjectId
  treatmentSessionId String @unique @db.ObjectId

  status CouponUsageStatus
  usedAt DateTime

  paymentId String?   @db.ObjectId
  expiresAt DateTime?

  // Relations
  coupon  Coupon           @relation(fields: [couponId], references: [id])
  patient Patient          @relation(fields: [patientId], references: [id])
  session TreatmentSession @relation(fields: [treatmentSessionId], references: [id])

  @@index([patientId])
}

model CouponAssignment {
  id        String               @id @default(auto()) @map("_id") @db.ObjectId
  couponId  String               @db.ObjectId
  patientId String               @db.ObjectId
  type      CouponAssignmentType

  coupon  Coupon  @relation(fields: [couponId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
}

model CouponTherapist {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  couponId    String @db.ObjectId
  therapistId String @db.ObjectId

  coupon    Coupon    @relation(fields: [couponId], references: [id])
  // No strict relation to Therapist model needed here unless you want cascading delete, 
  // but keeping ID is safe for flexible checking.
  therapist Therapist @relation(fields: [therapistId], references: [id])
}

// ----------------------------------------------------------------------
// CONTENT (BLOGS & REVIEWS)
// ----------------------------------------------------------------------

model Blog {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  summary   String
  tags      String
  thumbnail String
  slug      String @unique

  readTime String?
  views    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews BlogReview[]
  likes   BlogLike[]
}

model BlogReview {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  blogId String @db.ObjectId
  userId String @db.ObjectId // Author

  comment String

  createdAt DateTime @default(now())

  // Relations
  blog   Blog @relation(fields: [blogId], references: [id])
  author User @relation("WrittenReviews", fields: [userId], references: [id])
}

model BlogReviewLike {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  reviewId String @db.ObjectId
  userId   String @db.ObjectId

  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model BlogLike {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  blogId String @db.ObjectId
  userId String @db.ObjectId

  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([blogId])
}

// ----------------------------------------------------------------------
// REVIEWS (THERAPY)
// ----------------------------------------------------------------------

model TherapistReview {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String @db.ObjectId
  therapistId     String @db.ObjectId
  treatmentPlanId String @db.ObjectId

  rating  Float
  comment String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  patient   Patient   @relation("PatientGivenReviews", fields: [patientId], references: [id])
  therapist Therapist @relation("TherapistReceivedReviews", fields: [therapistId], references: [id])

  @@index([therapistId])
  @@index([patientId])
}

model TreatmentSessionReview {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String @unique @db.ObjectId

  reviewBy ReviewedBy
  comment  String
  rating   Float
  date     DateTime

  session TreatmentSession @relation(fields: [sessionId], references: [id])
}

// ----------------------------------------------------------------------
// SYSTEM
// ----------------------------------------------------------------------

model Activity {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  title  String
  data   String
  before String?
  after  String?
  ip     String
  type   ActivityType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  title       String
  description String
  isRead      Boolean
  priority    NotificationPriority

  createdAt DateTime @default(now())
  time      DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ----------------------------------------
// Contact and Complaint
// ----------------------------------------

enum ContactStatus {
  pending
  processing
  completed
  rejected
}

model contact {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  mobile    String
  type      String
  status    ContactStatus
  reply     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Complaint {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @unique @db.ObjectId
  type        String
  description String
  status      ContactStatus
  reply       Reply[]
  user        User          @relation(fields: [userId], references: [id])
}

model Reply {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  role        ReplyRole
  message     String
  complaintId String    @db.ObjectId
  complaint   Complaint @relation(fields: [complaintId], references: [id])
}

enum ReplyRole {
  user
  support
}
